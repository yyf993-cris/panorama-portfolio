# Notion Integration
# 1. 前往 https://www.notion.so/my-integrations 创建一个 Integration
# 2. 复制 Internal Integration Secret 填入下方
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxx

# Notion 数据库 ID
# 打开你的 Notion 数据库页面，URL 中 ?v= 前的那段32位字符就是 Database ID
# 例: https://notion.so/myworkspace/a8aec43384f447ed84390e8e42c2e089?v=...
#                                   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ 这部分
NOTION_DATABASE_ID=your_database_id_here

# Admin password reset secret (用于调用强制重置密码接口的密钥)
ADMIN_RESET_SECRET=your_random_secret_here
