# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# server runtime
.server.pid
.server.log
.server.log.err
.start-server.cmd
/log/
/.node/

# runtime data (views counter, works managed via admin)
/data/views.json
/data/works.json
/data/admin.json
/data/sessions.json

# generated assets (synced from assets/)
/public/works/

# typescript
*.tsbuildinfo
next-env.d.ts
